@page
@model MobileStore.Pages.Mobile.Edit
@{
    ViewData["Title"] = "Edit Mobile";
}

<h1>✏️ Edit Mobile</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <input type="hidden" asp-for="Id" />

            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Brand</label>
                <div class="col-sm-8">
                    <input class="form-control" asp-for="Brand" />
                    <span asp-validation-for="Brand" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Model</label>
                <div class="col-sm-8">
                    <input class="form-control" asp-for="Model" />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Price (₹)</label>
                <div class="col-sm-8">
                    <input class="form-control" asp-for="Price" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Focus</label>
                <div class="col-sm-8">
                    <select class="form-select" asp-for="Focus">
                        <option value="Gaming">🎮 Gaming</option>
                        <option value="Photography">📷 Photography</option>
                        <option value="General">📱 General</option>
                        <option value="Business">💼 Business</option>
                        <option value="Budget">💰 Budget</option>
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">RAM (GB)</label>
                <div class="col-sm-8">
                    <select class="form-select" asp-for="RamGb">
                        <option value="4">4 GB</option>
                        <option value="6">6 GB</option>
                        <option value="8">8 GB</option>
                        <option value="12">12 GB</option>
                        <option value="16">16 GB</option>
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Storage (GB)</label>
                <div class="col-sm-8">
                    <select class="form-select" asp-for="StorageGb">
                        <option value="64">64 GB</option>
                        <option value="128">128 GB</option>
                        <option value="256">256 GB</option>
                        <option value="512">512 GB</option>
                        <option value="1024">1 TB</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Update</button>
            <a asp-page="/mobile/Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
