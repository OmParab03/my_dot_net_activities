@page "{id:int}"
@model MobileStore.Pages.Mobile.Delete
@{
    ViewData["Title"] = "Delete Mobile";
}

<div class="mx-auto rounded border p-4" style="max-width: 450px;">
    <h2>🗑️ Delete Mobile</h2>
    <p class="text-danger">Are you sure you want to delete this record?</p>

    <p><strong>Brand:</strong> @Model.Brand</p>
    <p><strong>Model:</strong> @Model.Model</p>

    <form method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a asp-page="/mobile/Index" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>
